# Azure Sora / Foundry endpoint (no trailing slash)
AZURE_FOUNDRY_ENDPOINT=https://<azure-ai-account>.cognitiveservices.azure.com

# Azure Speech regional endpoint and resource identity
AZURE_SPEECH_REGION=eastus2
AZURE_SPEECH_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.CognitiveServices/accounts/<speech-account>

# Instead of AZURE_SPEECH_RESOURCE_ID, the generator can resolve it with:
# AZURE_SPEECH_ACCOUNT=<speech-account>
# AZURE_SPEECH_RESOURCE_GROUP=<resource-group>

AZURE_SORA_MODEL=sora-2
AZURE_SORA_API_VERSION=preview
