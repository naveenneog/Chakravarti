{
  "name": "chakravarti-chronicles",
  "private": true,
  "version": "0.7.4",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --outDir docs --emptyOutDir",
    "lint": "oxlint src vite.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node tests/smoke.mjs",
    "unity:windows": "powershell -ExecutionPolicy Bypass -File tooling\\build_unity.ps1 -Target Windows",
    "unity:android": "powershell -ExecutionPolicy Bypass -File tooling\\build_unity.ps1 -Target Android",
    "cap:add": "cap add android",
    "cap:sync": "npm run build && cap sync android",
    "apk": "powershell -ExecutionPolicy Bypass -File tooling\\build_apk.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@react-three/fiber": "^9.6.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "playwright-core": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^5.0.0-beta.5"
  }
}
